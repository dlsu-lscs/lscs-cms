DATABASE_URI=
PAYLOAD_SECRET=
PAYLOAD_AUTH_SECRET=

NEXT_PUBLIC_SERVER_URL=
NEXT_PUBLIC_PAYLOAD_AUTH_URL=

GOOGLE_CLIENT_SECRET=
GOOGLE_CLIENT_ID=

LSCS_CORE_API_TOKEN=
LSCS_CORE_API_URL=

S3_SECRET_ACCESS_KEY=
S3_ACCESS_KEY_ID=
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=

# Outgoing webhooks (CMS -> Archerbytes)
# Recommended: set ARCHERBYTES_WEBHOOK_BASE_URL to the archerbytes origin
ARCHERBYTES_WEBHOOK_BASE_URL=
# Optional: full override URL for Archerbytes webhook events
ARCHERBYTES_WEBHOOK_URL=

# Outgoing webhooks (CMS -> LSCS website)
# Recommended: set WEBHOOK_BASE_URL to your website's origin (e.g. https://your-domain.com)
WEBHOOK_BASE_URL=
# Optional: full override URL for all webhook events (takes precedence over WEBHOOK_BASE_URL)
WEBHOOK_URL=
# Shared secret used in Authorization: Bearer <secret>
WEBHOOK_SECRET=
# Set to true to log outgoing payloads and target URL
WEBHOOK_VERBOSE_LOGGING=false
